# IMAP (Eingehend)
IMAP_HOST=imap.example.com
IMAP_USER=deine@email.com
IMAP_PASSWORD=dein-app-passwort
IMAP_PORT=993

# SMTP (Ausgehend / Senden)
SMTP_HOST=smtp.example.com
SMTP_USER=deine@email.com
SMTP_PASSWORD=dein-app-passwort
SMTP_PORT=587

# Sicherheit - zufälligen Token generieren, z.B.: openssl rand -hex 32
MCP_AUTH_TOKEN=dein-geheimer-token

# Port (wird von Render automatisch gesetzt)
PORT=3000
