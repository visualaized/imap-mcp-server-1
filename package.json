{
  "name": "imap-mcp-server",
  "version": "1.2.0",
  "description": "A powerful Model Context Protocol (MCP) server for IMAP email integration with Claude",
  "main": "dist/index.js",
  "bin": {
    "imap-mcp": "./dist/index.js",
    "imap-setup": "./dist/setup.js"
  },
  "scripts": {
    "build": "node build.mjs",
    "build:tsc": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "setup": "tsx src/setup.ts",
    "web": "tsx src/web/server.ts",
    "start:http": "node dist/server-http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit --skipLibCheck"
  },
  "keywords": [
    "mcp",
    "imap",
    "email",
    "claude",
    "ai",
    "model-context-protocol"
  ],
  "author": "Michael Nikolaus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michaelnikolaus/imap-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/michaelnikolaus/imap-mcp-server/issues"
  },
  "homepage": "https://github.com/michaelnikolaus/imap-mcp-server#readme",
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.0.14",
    "@types/pdf-parse": "^1.1.5",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.27.2",
    "nodemon": "^3.1.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/nodemailer": "^6.4.17",
    "body-parser": "^2.2.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "imapflow": "^1.3.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.5",
    "open": "^10.2.0",
    "ora": "^8.2.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.25.76"
  },
  "overrides": {
    "qs": "^6.14.1"
  }
}
